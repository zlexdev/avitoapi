# Avito Partner API credentials.
# Get them from https://developers.avito.ru/ → "Создать приложение".
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=

# Only required for the authorization_code grant (multi-tenant dashboards).
# AVITO_USER_ID=
# AVITO_REDIRECT_URI=https://example.com/oauth/callback

# Override the OAuth token endpoint flavor if your account needs the GET variant.
# Default: post_form. Allowed: post_form | get_query.
# AVITO_OAUTH_GRANT_ENDPOINT=post_form

# Transport tuning.
# AVITO_REQUEST_TIMEOUT_S=30
# AVITO_MAX_RETRIES=5

# Private dependency token for installing `evented` from github.com/zlexdev/*.
GH_TOKEN=
