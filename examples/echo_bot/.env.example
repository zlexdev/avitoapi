# --- Avito OAuth credentials (single-account form) -------------------------
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_USER_ID=

# --- Multi-account form (overrides single-account vars when set) -----------
# Comma-separated account ids. For each id:
#   AVITO_CLIENT_ID_<id>      = ...
#   AVITO_CLIENT_SECRET_<id>  = ...
#   AVITO_USER_ID_<id>        = ...
AVITO_ACCOUNT_IDS=

# --- Webhook ---------------------------------------------------------------
AVITO_WEBHOOK_SECRET=
WEBHOOK_PATH=/messenger
PORT=8080
HOST=0.0.0.0

# --- Operations ------------------------------------------------------------
LOG_LEVEL=INFO
